# --- Локальный inference (LM Studio / Ollama) ---
# LM Studio: lms server start  →  http://127.0.0.1:1234/v1
# Ollama:    ollama serve      →  http://127.0.0.1:11434/v1
LLM_AGENT_BACKEND=local
LLM_AGENT_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LLM_AGENT_LOCAL_MODEL=
LLM_AGENT_LOCAL_API_KEY=lm-studio

# --- Приватный HTTP-сервис (python -m llm_service) ---
LLM_SERVICE_HOST=0.0.0.0
LLM_SERVICE_PORT=8080
LLM_SERVICE_API_KEY=change-me-home-secret
LLM_SERVICE_REQUIRE_API_KEY=1
LLM_SERVICE_RATE_LIMIT_RPM=30
LLM_SERVICE_MAX_CONCURRENT=2
LLM_SERVICE_MAX_CONTEXT_MESSAGES=50
LLM_SERVICE_MAX_MESSAGE_CHARS=16000
LLM_SERVICE_SESSION_TTL_SEC=3600
LLM_SERVICE_MAX_SESSIONS=100
# LLM_SERVICE_HISTORY_DIR=./memory/service_sessions

# Генерация (опционально)
# LLM_AGENT_TEMPERATURE=0.7
# LLM_AGENT_MAX_TOKENS=1024
# LLM_AGENT_CONTEXT_WINDOW=6
